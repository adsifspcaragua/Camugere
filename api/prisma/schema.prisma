// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario{
  id      Int       @id @default(autoincrement())
  nome    String    @db.VarChar(20)
  email   String    @unique @db.VarChar(40) 
  hash    String

  leitores Leitor[]
  bibliotecarios Bibliotecario[]
}

model Leitor{
  id   Int   @id @default(autoincrement())
  id_usuario  Int   @unique
  usuario   Usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cpf  String   @db.VarChar(14)   @unique   
  telefone  String?    @db.VarChar(11)
}

model Bibliotecario{
  id   Int   @id @default(autoincrement())
  id_usuario  Int
  usuario   Usuario   @relation(fields: [id_usuario], references: [id], onDelete:Cascade)
}

LeitorClube{
  id_leitor   Int   
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], onDelete:Cascade)
  id_clube    Int
  clube   Clube   @relation(fields: [id_clube], references: [id], onDelete:Cascade)

  @@id([id_leitor], [id_clube])
}

model Clube{
  id    Int   @id @default(autoincrement())
  nome    String    @db.VarChar(40)
  descricao   String?
  dataCriacao   DateTime
  status    String
}

model Obra{
  id    Int   @id @default(autoincrement())
  titulo    String    @db.VarChar(200)
  autor     String    @db.VarChar(200)
  cdd       String    @db.Varchar(200)
  ativa     Boolean   @default(true)
  notaMedia   Float

  @@check([notaMedia <= 5], name: "nota-maxima")     
  @@check([notaMedia >= 0], name: "nota-minima")     
}

model Exemplar{
  id    Int   @id @default(autoincrement())
  id_obra   Int
  obra    Obra    @relation(fields: [id_obra], references: [id], OnDelete:Cascade)
  numeroInventario     String     @db.Varchar(6)
  disponivel      Boolean     @default(true)
}

model Emprestimo{
  id    Int     @id @default(autoincrement())
  dataInicio    DateTime
  diasLocacao   Int 
  id_leitor     Int
  leitor    Leitor    @realtion(fields: [id_obra], references: [id], OnDelete:Cascade)
  id_exemplar   Int
  exemplar    Emprestimo    @relation(fields: [id_exemplar], references: [id], OnDelete:Cascade)

  @@check([diasLocacao <= 15], name: "dias-maximo")     
  @@check([diasLocacao >= 0], name: "dias-minimo")
}

model Reserva{
  id    Int   @id @default(autoincrement())
  dataReserva     DateTime
  id_obra    Int
  obra    Obra @relation(fields: [id_obra], references: [id], OnDelete:Cascade)
  id_leitor     Int
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], OnDelete:Cascade)
}

model Comentario{
  id    Int   @id @default(autoincrement())
  texto   String?    @db.VarChar(1000)   @null
  dataPublicacao    DateTime
  nota    Int?    @null
  curtidas    Int     @default(0)
  moderado    Boolean     @default(false)

  id_obra     Int
  obra    Obra    @relation(fields: [id_obra], references: [id], OnDelete:Cascade)
  id_leitor   Int
  leitor    Leitor    @relation(fields: [id_leitor], references[id], OnDelete:Cascade)    
}