// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario{
  id      Int       @id @default(autoincrement())
  nome    String    @db.VarChar(20)
  email   String    @unique @db.VarChar(40) 
  hash    String

  leitores Leitor[]
  bibliotecarios Bibliotecario[]
}

model Leitor{
  id   Int   @id @default(autoincrement())
  id_usuario  Int
  usuario   Usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
  cpf  String   @db.VarChar(14)   @unique   
  telefone  String?    @db.VarChar(11)

  leitorClubes LeitorClube[]
  emprestimos Emprestimo[]
  comentarios Comentario[]
  reservas Reserva[]
}

model Bibliotecario{
  id   Int   @id @default(autoincrement())
  id_usuario  Int
  usuario   Usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade)
}

model Obra{
  id    Int   @id @default(autoincrement())
  titulo    String    @db.VarChar(200)
  subtitulo    String?    @db.VarChar(200)
  editora   String?    @db.VarChar(100)
  edicao    String?    @db.VarChar(20)
  numeroPaginas   Int
  capa      String?
  ativa     Boolean   @default(true)
  notaMedia   Float?

  id_cdd    String    @db.VarChar(6)     
  cdd   Cdd   @relation(fields: [id_cdd], references: [id], onDelete: Cascade)

  exemplares Exemplar[]
  reservas Reserva[]
  comentarios Comentario[]
  autores ObraAutor[]
}

model ObraAutor{
  id_obra    Int
  obra    Obra    @relation(fields: [id_obra], references: [id], onDelete: Cascade)
  id_autor   Int
  autor   Autor   @relation(fields: [id_autor], references: [id], onDelete: Cascade)

  @@id([id_obra, id_autor])
}

model Autor{
  id    Int   @id @default(autoincrement())
  nome    String    @db.VarChar(40)
  sobrenome    String    @db.VarChar(40)

  obras ObraAutor[]
}

model Cdd{
  id    String    @db.VarChar(6)   @id
  descricao   String  @db.VarChar(100)

  obras Obra[]
}

model Clube{
  id    Int   @id @default(autoincrement())
  nome    String    @db.VarChar(40)
  descricao   String?
  dataCriacao   DateTime
  status    String

  leitorClubes LeitorClube[]
}

model LeitorClube{
  id_leitor   Int   
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], onDelete: Cascade)
  id_clube    Int
  clube   Clube   @relation(fields: [id_clube], references: [id], onDelete: Cascade)

  @@id([id_leitor, id_clube])
}

model Exemplar{
  id    Int   @id @default(autoincrement())
  id_obra   Int
  obra    Obra    @relation(fields: [id_obra], references: [id], onDelete: Cascade)
  numeroInventario     String     @db.VarChar(6)
  disponivel      Boolean     @default(true)

  emprestimos Emprestimo[]
}

model Emprestimo{
  id    Int     @id @default(autoincrement())
  dataInicio    DateTime    @default(now())
  diasLocacao   Int
  statusDevolucao   Boolean   @default(false)
  dataDevolucao     DateTime?    
  
  id_leitor     Int
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], onDelete: Cascade)

  id_exemplar   Int
  exemplar    Exemplar    @relation(fields: [id_exemplar], references: [id], onDelete: Cascade)

}

model Reserva{
  id    Int   @id @default(autoincrement())
  dataReserva     DateTime
  id_obra    Int
  obra    Obra @relation(fields: [id_obra], references: [id], onDelete: Cascade)
  id_leitor     Int
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], onDelete: Cascade)
}

model Comentario{
  id    Int   @id @default(autoincrement())
  dataPublicacao    DateTime
  texto   String?    @db.VarChar(1000)
  nota    Int?
  curtidas    Int     @default(0)
  moderado    Boolean     @default(false)

  id_obra     Int
  obra    Obra    @relation(fields: [id_obra], references: [id], onDelete: Cascade)
  id_leitor     Int
  leitor    Leitor    @relation(fields: [id_leitor], references: [id], onDelete: Cascade)
}